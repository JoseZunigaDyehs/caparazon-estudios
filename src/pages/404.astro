---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Página no encontrada | Caparazón Estudios"
  description="La página que buscas no existe. Vuelve al inicio de Caparazón Estudios."
  robots="noindex, follow"
>
  <main class="bg-brand-surface text-brand-text-main font-sans min-h-screen flex items-center justify-center px-6">
    <div class="text-center max-w-xl">
      <div class="text-8xl font-bold text-brand-primary mb-6" aria-hidden="true">
        404
      </div>
      <h1 class="text-3xl md:text-4xl font-bold mb-4">
        Página no encontrada
      </h1>
      <p class="text-brand-text-muted text-lg mb-10 leading-relaxed">
        La ruta que buscas no existe o fue movida. Te ayudamos a volver a
        construir algo sólido.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 bg-brand-primary text-brand-surface px-8 py-4 rounded-xl font-bold text-lg hover:shadow-[0_0_20px_rgba(0,196,159,0.3)] transition-all"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-5 h-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          aria-hidden="true"
        >
          <path d="M19 12H5M12 19l-7-7 7-7"></path>
        </svg>
        Volver al inicio
      </a>
    </div>
  </main>
</Layout>
