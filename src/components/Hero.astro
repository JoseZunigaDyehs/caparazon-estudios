<section id="inicio" class="relative pt-40 pb-12 md:pb-20 px-6 overflow-hidden">
  <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-12 items-center">
    <div>
      <div
        class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-card border border-brand-border text-[12px] font-mono tracking-widest text-brand-primary mb-6 uppercase"
      >
        <span class="relative flex h-2 w-2" aria-hidden="true">
          <span
            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-primary opacity-75"
          ></span>
          <span
            class="relative inline-flex rounded-full h-2 w-2 bg-brand-primary"
          ></span>
        </span>
        Ingeniería Web de Élite
      </div>

      <h1
        class="text-3xl md:text-5xl font-bold leading-[1.1] tracking-tight mb-6"
      >
        Arquitectura web ultra resistente y de <span
          class="italic text-brand-primary">alta velocidad.</span
        >
      </h1>

      <p class="text-lg text-brand-text-muted leading-relaxed max-w-xl mb-10">
        Diseñamos e-commerce y catálogos headless de alto rendimiento que
        protegen tu negocio, reducen tus costos de hosting a cero y cargan en
        menos de 1 segundo en el celular.
      </p>

      <div class="flex flex-wrap gap-4">
        <a
          href="#cotizar"
          class="cursor-pointer bg-brand-primary text-brand-surface px-8 py-4 rounded-xl font-bold text-lg flex items-center gap-2 hover:shadow-[0_0_20px_rgba(0,196,159,0.3)] transition-all"
          data-track-event="cta_click"
          data-track-params='{"cta_location":"hero_primary","cta_text":"Cotizar mi Proyecto"}'
        >
          Cotizar mi Proyecto
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2.5"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
          >
        </a>
        <a
          href="#casos"
          class="cursor-pointer border border-brand-border text-brand-text-main px-8 py-4 rounded-xl font-bold text-lg hover:bg-brand-card transition-colors"
          data-track-event="cta_click"
          data-track-params='{"cta_location":"hero_secondary","cta_text":"Explorar Casos"}'
        >
          Explorar Casos
        </a>
      </div>

      <div
        class="grid grid-cols-3 gap-8 mt-16 pt-8 border-t border-brand-border/50"
      >
        <div>
          <div class="text-2xl font-bold text-brand-primary">0%</div>
          <div
            class="text-[12px] font-mono text-brand-text-muted uppercase tracking-wider"
          >
            Comisiones por Venta
          </div>
        </div>
        <div>
          <div class="text-2xl font-bold text-brand-primary">Verde</div>
          <div
            class="text-[12px] font-mono text-brand-text-muted uppercase tracking-wider"
          >
            Core Web Vitals
          </div>
        </div>
        <div>
          <div class="text-2xl font-bold text-brand-primary">Inmune</div>
          <div
            class="text-[12px] font-mono text-brand-text-muted uppercase tracking-wider"
          >
            A Caídas y Hackeos
          </div>
        </div>
      </div>
    </div>

    <div class="relative hidden md:flex justify-center items-center">
      <div class="relative w-full aspect-square max-w-md">
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="relative w-full h-full flex items-center justify-center">
            <!-- Tarjeta Principal (Base de datos y barra) -->
            <div
              class="w-64 h-64 border border-(--color-caparazon-primary)/30 rounded-3xl bg-(--color-caparazon-surface)/40 backdrop-blur-xl p-6 flex flex-col justify-between transform -rotate-6 z-20 shadow-2xl"
            >
              <div class="flex justify-between items-start">
                <!-- Icono simulado con SVG nativo para no depender de fuentes externas si no las tienes cargadas -->
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  class="w-9 h-9 text-(--color-caparazon-primary)"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0v3.75"
                  ></path>
                </svg>
                <span
                  class="font-mono text-[10px] text-(--color-caparazon-primary)/80 border border-(--color-caparazon-primary)/20 px-2 py-1 rounded tracking-wide"
                  >ESTADO: ACTIVO</span
                >
              </div>
              <div>
                <div
                  class="w-full h-2 bg-(--color-caparazon-bg) rounded-full mb-2 overflow-hidden border border-(--color-caparazon-muted)/20"
                >
                  <div
                    class="w-3/4 h-full bg-(--color-caparazon-primary) rounded-full shadow-[0_0_12px_rgba(0,196,159,0.5)]"
                  >
                  </div>
                </div>
                <div
                  class="font-mono text-[11px] text-(--color-caparazon-text) uppercase tracking-wider"
                >
                  Procesamiento Estructurado
                </div>
              </div>
            </div>

            <!-- Globo de Score 100 (Estilo Neumórfico/Glow) -->
            <div
              class="absolute top-10 right-4 bg-(--color-caparazon-primary) text-(--color-caparazon-bg) p-4 rounded-2xl transform rotate-12 z-30 flex flex-col items-center shadow-[0_10px_25px_-5px_rgba(0,196,159,0.4)]"
            >
              <span
                class="text-3xl font-extrabold leading-none tracking-tighter"
                >100</span
              >
              <span
                class="font-mono text-[9px] uppercase font-bold tracking-widest mt-1"
                >Score</span
              >
            </div>

            <!-- Tarjeta Secundaria (Terminal de Deploy) -->
            <div
              class="absolute bottom-10 -left-4 w-56 h-40 border border-(--color-caparazon-muted)/20 rounded-2xl bg-(--color-caparazon-surface)/70 backdrop-blur-md p-4 z-10 transform rotate-3 flex flex-col gap-3 shadow-xl"
            >
              <div class="flex gap-1.5">
                <div class="w-2.5 h-2.5 rounded-full bg-red-500/80"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-yellow-500/80"></div>
                <div
                  class="w-2.5 h-2.5 rounded-full bg-(--color-caparazon-primary)/80"
                >
                </div>
              </div>
              <div class="space-y-2 mt-2">
                <div class="h-1 w-full bg-(--color-caparazon-muted)/30 rounded">
                </div>
                <div class="h-1 w-2/3 bg-(--color-caparazon-muted)/20 rounded">
                </div>
                <div class="h-1 w-4/5 bg-(--color-caparazon-muted)/20 rounded">
                </div>
              </div>
              <div
                class="mt-auto flex items-center gap-2 text-(--color-caparazon-muted)"
              >
                <!-- Icono de terminal SVG en vez del tag de Google Fonts -->
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="2"
                  stroke="currentColor"
                  class="w-3.5 h-3.5 text-(--color-caparazon-primary)"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m3.75-3 3 18"
                  ></path>
                </svg>
                <span class="font-mono text-[10px] tracking-tight"
                  >deploy_success_v2.0</span
                >
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

