---
import CaparazonSvg from "../assets/caparazon.svg";
---

<footer class="px-6 py-20 border-t border-brand-border/30">
  <div class="max-w-6xl mx-auto grid md:grid-cols-4 gap-12 mb-0 md:mb-20">
    <div class="md:col-span-2">
      <a href="#inicio" class="flex items-center gap-2 mb-6 group">
        <CaparazonSvg
          class="w-7 h-7"
          role="img"
          aria-label="Caparazón Estudios"
        />

        <span class="font-bold tracking-tighter text-lg"
          >CAPARAZÓN ESTUDIOS</span
        >
      </a>
      <p class="text-brand-text-muted text-sm leading-relaxed max-w-sm">
        Arquitectos de software dedicados a la excelencia técnica y la
        durabilidad digital. Built with precision for high-end engineering.
      </p>
    </div>

    <div>
      <h2
        class="text-[12px] font-mono text-brand-text-muted uppercase tracking-widest mb-6"
      >
        Sitemap
      </h2>
      <ul class="space-y-4 text-sm text-brand-text-muted">
        <li>
          <a href="#inicio" class="hover:text-brand-primary transition-colors"
            >Inicio</a
          >
        </li>
        <li>
          <a href="#casos" class="hover:text-brand-primary transition-colors"
            >Casos de Éxito</a
          >
        </li>
        <li>
          <a
            href="#servicios"
            class="hover:text-brand-primary transition-colors">Servicios</a
          >
        </li>
      </ul>
    </div>

    <div>
      <h2
        class="text-[12px] font-mono text-brand-text-muted uppercase tracking-widest mb-6"
      >
        Legal
      </h2>
      <ul class="space-y-4 text-sm text-brand-text-muted">
        <li>
          <a
            href="/privacidad"
            class="hover:text-brand-primary transition-colors">Privacidad</a
          >
        </li>
        <li>
          <a href="/terminos" class="hover:text-brand-primary transition-colors"
            >Términos</a
          >
        </li>
        <li>
          <a href="#cotizar" class="hover:text-brand-primary transition-colors"
            >Contacto</a
          >
        </li>
      </ul>
    </div>
  </div>

  <div
    class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6 pt-12 border-t border-brand-border/10"
  >
    <div class="text-[14px] font-mono text-brand-text-muted">
      © 2024 CAPARAZÓN ESTUDIOS.
    </div>
    <div class="flex gap-4">
      <a
        href="mailto:hola@caparazonestudios.com"
        class="p-3.5 border border-brand-border rounded-lg hover:border-brand-primary transition-colors inline-flex"
        aria-label="Enviar correo a Caparazón Estudios"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4 text-brand-text-muted"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
          ><rect width="20" height="16" x="2" y="4" rx="2"></rect><path
            d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg
        >
      </a>
      <a
        href="https://github.com/caparazonestudios"
        target="_blank"
        rel="noopener noreferrer"
        class="p-3.5 border border-brand-border rounded-lg hover:border-brand-primary transition-colors inline-flex"
        aria-label="GitHub de Caparazón Estudios"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4 text-brand-text-muted"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
          ><path
            d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
          ></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg
        >
      </a>
    </div>
    <div class="text-[14px] font-mono text-brand-text-muted tracking-widest">
      BUILT WITH PRECISION BY CAPARAZÓN ESTUDIOS.
    </div>
  </div>
</footer>
